#compdef ori
#
# zsh completion for ori. Symlinked into ~/.local/share/zsh-completions/
# by dotfiles install.sh §3, then loaded automatically by .zshrc.
#
# Two-stage completion for project/branch:
#   ori start <TAB>                    → list projects (with trailing /)
#   ori start <project>/<TAB>          → list that project's branches
#                                        (default branch is 'main')

_ori_start_target() {
  local cur="${words[CURRENT]}"
  if [[ "$cur" == */* ]]; then
    local project="${cur%%/*}"
    local -a branches
    branches=(${(f)"$(ori pointer list --format=branches=$project 2>/dev/null)"})
    compadd -P "$project/" -- $branches
  else
    local -a projects
    projects=(${(f)"$(ori projects 2>/dev/null)"})
    compadd -S '/' -- $projects
  fi
}

_ori_workshops() {
  local -a workshops
  workshops=(${(f)"$(ori workshop list 2>/dev/null | awk 'NR>1 && $1!="" {print $1}')"})
  compadd -- $workshops
}

_ori_projects() {
  local -a projects
  projects=(${(f)"$(ori projects 2>/dev/null)"})
  compadd -- $projects
}

_ori() {
  local context state line
  typeset -A opt_args

  _arguments -C \
    '1:command:->cmd' \
    '*::arg:->args'

  case $state in
    cmd)
      local -a subs
      subs=(
        'start:start (or resume) a project/branch'
        'resume:re-attach to an existing session'
        'attach:attach to a cloudcode serve (headless)'
        'stop:stop a serve process'
        'shell:open a terminal next to the session'
        'sh:alias for shell'
        'status:trail UI: live sessions'
        's:alias for status'
        'projects:list projects'
        'p:alias for projects'
        'project:project management'
        'doc:read/append project docs'
        'pointer:manage pointers'
        'session:manage sessions'
        'workshop:manage workshops'
        'fleet:per-workshop drift table'
        'artifacts:artifact registry'
        'handoff:cross-session handoff bundles'
        'install:wire ori into harnesses on this host'
        'upgrade:self-upgrade the ori binary'
        'auth:manage credentials'
        'mcp:MCP server commands'
        'vault:vault management'
      )
      _describe -t commands 'ori command' subs
      ;;
    args)
      case $line[1] in
        start|shell|sh|resume|attach|stop)
          # Complete --workshop <id> if the previous word is --workshop;
          # otherwise complete the project[/branch] target.
          if [[ "${words[CURRENT-1]}" == "--workshop" ]]; then
            _ori_workshops
          else
            _ori_start_target
          fi
          ;;
        pointer)
          if (( CURRENT == 2 )); then
            local -a sub=(list show set state suspend resume abandon clear rename)
            compadd -- $sub
          else
            _ori_start_target
          fi
          ;;
        workshop|workshops)
          if (( CURRENT == 2 )); then
            local -a sub=(
              list show add remove rename ssh attach run probe
              ssh-config tmux here bootstrap observed desired
            )
            compadd -- $sub
          else
            _ori_workshops
          fi
          ;;
        doc)
          if (( CURRENT == 2 )); then
            local -a sub=(read append)
            compadd -- $sub
          else
            _ori_projects
          fi
          ;;
        project)
          if (( CURRENT == 2 )); then
            local -a sub=(list show create set)
            compadd -- $sub
          else
            _ori_projects
          fi
          ;;
        session)
          if (( CURRENT == 2 )); then
            local -a sub=(list show register suspend resume abandon)
            compadd -- $sub
          fi
          ;;
        vault)
          if (( CURRENT == 2 )); then
            local -a sub=(
              list show config checkpoint refresh append-agents
              audit-fortification install-hook validate
            )
            compadd -- $sub
          fi
          ;;
        mcp)
          if (( CURRENT == 2 )); then
            local -a sub=(serve list)
            compadd -- $sub
          fi
          ;;
        fleet)
          if (( CURRENT == 2 )); then
            local -a sub=(status drift)
            compadd -- $sub
          fi
          ;;
        artifacts|artifact)
          if (( CURRENT == 2 )); then
            local -a sub=(list get add remove rm)
            compadd -- $sub
          fi
          ;;
        handoff|handoffs)
          if (( CURRENT == 2 )); then
            local -a sub=(list show start sanitize approve send ack)
            compadd -- $sub
          fi
          ;;
        auth)
          if (( CURRENT == 2 )); then
            local -a sub=(github status clear)
            compadd -- $sub
          fi
          ;;
      esac
      ;;
  esac
}

_ori "$@"
