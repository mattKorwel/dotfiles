#compdef ori
#
# zsh completion for ori (v3 — keystore brain, scope-based).
#
# Symlinked into ~/.local/share/zsh-completions/_ori by dotfiles
# install.sh §3, then loaded automatically by .zshrc.
#
# Two-stage scope completion:
#   ori start <TAB>                → top-level scopes (with trailing /)
#   ori start amplify/<TAB>        → amplify's children
#   ori start amplify/ori/<TAB>    → amplify/ori's children
#
# `ori scope list <path> --flat` returns immediate children only,
# one indented row per scope. We strip the indent + the trailing
# metadata columns to get bare scope names.

_ori_scope_children() {
  # $1 = parent scope path (empty for root)
  local parent="$1"
  local -a out
  out=(${(f)"$(ori scope list ${parent:+$parent} --flat 2>/dev/null \
                | awk 'NR>1 && $1!="" {print $1}')"})
  print -l -- $out
}

_ori_scope_path() {
  # Walks dotted path, completing one component at a time.
  local cur="${words[CURRENT]}"
  local parent=""
  local prefix=""
  if [[ "$cur" == */* ]]; then
    parent="${cur%/*}"
    prefix="$parent/"
  fi
  local -a children
  children=(${(f)"$(_ori_scope_children "$parent")"})
  if (( ${#children} == 0 )); then
    return 1
  fi
  # Single compadd with `-S /` appends a slash so the user can keep
  # walking; zsh's autoremovable-suffix machinery strips it when the
  # next char is a space (terminating the word). No need for a second
  # no-suffix compadd — that just doubled every entry.
  compadd -P "$prefix" -S / -- $children
}

_ori_top_scopes() {
  local -a scopes
  scopes=(${(f)"$(_ori_scope_children '')"})
  compadd -S / -- $scopes
}

_ori_brokers() {
  # Static list matching fleet.toml + capsule conventions. Update
  # when bringing new hosts online.
  local -a brokers=(mac prime alpha beta auto)
  compadd -- $brokers
}

_ori_harnesses() {
  local -a h=(cloudcode gemini jetski)
  compadd -- $h
}

_ori() {
  local context state line
  typeset -A opt_args

  _arguments -C \
    '1:command:->cmd' \
    '*::arg:->args'

  case $state in
    cmd)
      local -a subs
      subs=(
        # daily driver
        'status:fleet view OR scope card'
        'start:launch a harness on a broker'
        'sit:join the broker tmux session'
        'whereami:print resolved scope and source'

        # content
        'plan:read | write | list | summarize'
        'learning:read | append | rewrite | summarize'
        'learnings:alias for learning'

        # scopes
        'scope:create | list | show | set | delete | pointer | session'
        'scopes:alias for scope'

        # raw
        'read:raw item read'
        'write:raw item write'
        'delete:raw item delete'
        'list:list items at scope'

        # dispatch / capsules
        'dispatch:multi-broker dispatch (Phase F)'
        'capsule:fleet inventory: sync | list | show'
        'capsules:alias for capsule'

        # infra
        'server:run the HTTP API'
        'mcp:stdio JSON-RPC for harnesses'
        'auth:set | show | ping'
        'bridge:install | uninstall (cloudcode plugin)'
        'publish:build, cross-compile, citc, hg submit'

        # meta
        'version:print version'
        'help:print usage'
      )
      _describe -t commands 'ori command' subs
      ;;
    args)
      case $line[1] in
        start)
          # Flag-aware: complete --broker NAME, --harness NAME, --cwd DIR.
          case "${words[CURRENT-1]}" in
            --broker)  _ori_brokers; return ;;
            --harness) _ori_harnesses; return ;;
            --cwd)     _path_files -/; return ;;
          esac
          # Otherwise: scope path.
          if (( CURRENT == 2 )) && [[ -z "${words[CURRENT]}" ]]; then
            _ori_top_scopes
          else
            _ori_scope_path
          fi
          ;;

        sit)
          case "${words[CURRENT-1]}" in
            --broker) _ori_brokers; return ;;
          esac
          _ori_scope_path
          ;;

        status|plan|learning|learnings|read|write|delete|list|dispatch)
          # First non-verb arg is a scope path; subcommands handled
          # by their own --help. Keep this simple.
          _ori_scope_path
          ;;

        scope|scopes)
          if (( CURRENT == 2 )); then
            local -a sub=(
              'create:create a scope'
              'list:list children (recursive tree by default)'
              'show:show one scope'
              'set:edit metadata'
              'delete:delete a scope'
              'set-default:bind fs path -> scope'
              'unset-default:unbind fs path'
              'pointer:clear | prune'
              'session:list sessions'
            )
            _describe -t scope-sub 'scope subcommand' sub
          else
            case "$words[2]" in
              pointer|session)
                if (( CURRENT == 3 )); then
                  case "$words[2]" in
                    pointer) compadd clear prune ;;
                    session) compadd list ;;
                  esac
                else
                  _ori_scope_path
                fi
                ;;
              *)
                _ori_scope_path
                ;;
            esac
          fi
          ;;

        capsule|capsules)
          if (( CURRENT == 2 )); then
            compadd sync list show
          fi
          ;;

        server)
          if (( CURRENT == 2 )); then
            compadd serve help
          fi
          ;;

        mcp)
          if (( CURRENT == 2 )); then
            compadd serve
          fi
          ;;

        auth)
          if (( CURRENT == 2 )); then
            compadd set show ping
          fi
          ;;

        bridge)
          if (( CURRENT == 2 )); then
            compadd install uninstall
          fi
          ;;

        publish)
          # No positional args; just complete flags.
          _arguments \
            '--message[commit message body]:msg:' \
            '--client-name[hgd client name]:name:' \
            '--reuse-client[skip hg hgd; use this client root]:dir:_path_files -/' \
            '--skip-tests[do not run go test]' \
            '--no-git[skip git commit/push]' \
            '--no-submit[stop after hg uploadchain]' \
            '--allow-dirty[do not refuse on dirty git tree]' \
            '--print[dry-run]'
          ;;
      esac
      ;;
  esac
}

_ori "$@"
