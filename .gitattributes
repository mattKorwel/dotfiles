# Force LF (Unix) line endings for all shell scripts and dotfiles
# to prevent Zsh parse errors on Windows/WSL.
*.sh text eol=lf
profiles/.zshrc text eol=lf
profiles/.bashrc text eol=lf
profiles/.bash_profile text eol=lf
.config/git/gitconfig.shared text eol=lf
.config/starship.toml text eol=lf
.config/mise/config.toml text eol=lf
.config/tmux/tmux.conf text eol=lf
.config/aerospace/aerospace.toml text eol=lf

# PowerShell files should use CRLF
*.ps1 text eol=crlf
