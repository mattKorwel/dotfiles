{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.40/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME\\applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Swap",
  "default_workspace_padding": 2,
  "default_container_padding": 2,
  "border": true,
  "border_width": 6,
  "border_offset": -1,
  "border_colors": {
    "active": "#64B4FF",
    "inactive": "#424242"
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "Dev",
          "layout": "Grid",
          "layout_options": {
            "grid": { "rows": 2 },
            "column_ratios": [0.25, 0.50]
          }
        },
        {
          "name": "Social",
          "layout": "Grid"
        },
        {
          "name": "Media",
          "layout": "Grid"
        },
        {
          "name": "Misc",
          "layout": "Grid"
        }
      ]
    }
  ]
}
